---
import type { MarkdownInstance } from "astro";
import type { Post } from "../../types/post";

import PostPreviewItem from "./PostPreviewItem.astro";
import ArrowSVG from "../../../public/svg/arrow.svg";

const posts = Object.values(
    import.meta.glob<MarkdownInstance<Post>>("../../pages/posts/*.md", {
        eager: true,
    }),
);

const postsList = posts
    .sort(
        (a, b) =>
            +new Date(b.frontmatter.pubDate) - +new Date(a.frontmatter.pubDate),
    )
    .slice(0, 10);
---

<section>
    <div class="swiper-posts-preview">
        <div class="swiper-wrapper">
            {
                postsList.map(({ frontmatter }) => (
                    <li class="swiper-slide">
                        <PostPreviewItem
                            title={frontmatter.title}
                            image={{
                                url: frontmatter.image.url,
                                alt: frontmatter.image.alt,
                            }}
                            previewImage={
                                frontmatter.previewImage && {
                                    url: frontmatter.previewImage.url,
                                    alt: frontmatter.previewImage.alt,
                                }
                            }
                            country={frontmatter.country}
                            categories={frontmatter.categories}
                            slug={frontmatter.slug}
                        />
                    </li>
                ))
            }
        </div>
        <button class="swiper-button-prev control" type="button">
            <ArrowSVG class="svg" />
        </button>
        <button class="swiper-button-next control" type="button">
            <ArrowSVG class="svg" />
        </button>
    </div>
</section>

<style>
    section {
        position: relative;
        margin-bottom: 100px;
        padding: 0 93px;
    }

    .swiper-posts-preview {
        overflow: hidden;
    }

    .control {
        top: 200px;
        width: 62px;
        height: 47px;
        padding: 10px;
        background-color: var(--color-white);

        &::after {
            display: none;
        }

        &.swiper-button-prev {
            left: 55px;
        }

        &.swiper-button-next {
            transform: scaleX(-1);
            right: 55px;
        }

        &:hover .svg {
            line {
                transform: scaleX(0.7);
                transform-origin: 55% 0;
            }

            polyline {
                translate: 5px 0;
            }
        }

        .svg g > * {
            transition: var(--transition-svg);
        }
    }
</style>

<script>
    import "swiper/css";
    import "swiper/css/navigation";

    import Swiper from "swiper";
    import { Navigation } from "swiper/modules";

    const swiper = new Swiper(".swiper-posts-preview", {
        modules: [Navigation],
        loop: true,
        slidesPerView: 5,
        spaceBetween: 9,
        navigation: {
            nextEl: ".swiper-button-next",
            prevEl: ".swiper-button-prev",
        },
    });
</script>
