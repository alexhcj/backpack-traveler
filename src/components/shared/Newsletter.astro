---
interface Props {
    type?: "grey"; // indeed for footer
}

const { type } = Astro.props;
---

<div class={`newsletter ${type}`}>
    <div class="ui-sidebar-title-wrapper">
        <h3 class="ui-sidebar-title bg-line">Newsletter</h3>
    </div>
    <form class="form">
        <input
            class="input"
            type="text"
            id="email"
            name="email"
            placeholder="Email address"
        />
        <button class="ui-button-primary">Subscribe</button>
    </form>
</div>

<style>
    .newsletter {
        text-align: center;

        &.grey {
            display: grid;

            .ui-sidebar-title {
                color: var(--color-grey-5);
            }
        }
    }
    .ui-sidebar-title-wrapper {
        margin-bottom: 18px;
    }
    .ui-sidebar-title {
        line-height: 1.8;
    }
    .form {
        display: flex;
        flex-direction: column;
        justify-self: center;
        gap: 13px;
        max-width: 315px;
        width: 100%;
    }
    .input {
        padding: 9px 16px;
        font-size: 12px;
        color: var(--color-grey-2);
        font-family: var(--family-montserrat);
        font-style: italic;
        border: 1px solid var(--color-dark-3);
        transition: var(--transition-default-4);

        &::placeholder {
            text-transform: capitalize;
            font-family: var(--family-montserrat);
        }

        &:focus {
            color: var(--color-dark);
            border-color: var(--color-black);
        }
    }
</style>
